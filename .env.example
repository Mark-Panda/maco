# LLM API keys (at least one required for chat)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Callback / SSE log redaction: basic | off
MACO_LOG_REDACT=basic

# PII guardrail (email/phone/SSN/card) on agent I/O + SSE: on by default, set off to disable
# MACO_GUARDRAIL_PII=off

# Auth: default off for local dev; set false + create token for production
MACO_AUTH_DISABLED=true

# Logging (RUST_LOG overrides default maco=info)
# RUST_LOG=maco=debug,tower_http=debug

# Data paths: optional ~/.maco/config.toml overrides defaults under ~/.maco/data/
# See README.md for config.toml schema (maco.db, sessions.db, memory.db, artifacts/)

# Explicit bind warning: server defaults to 127.0.0.1 only
# MACO_BIND_EXPLICIT=1

# Context compaction (ADK Runner); MACO_COMPACTION=0 disables
# MACO_COMPACTION_INTERVAL=5
# MACO_COMPACTION_OVERLAP=2
# MACO_INTRA_COMPACTION_TOKENS=80000
# MACO_CONTEXT_BUDGET=96000

# Tool concurrency (ADK RunConfig); MACO_TOOL_CONCURRENCY=0 disables
# MACO_TOOL_CONCURRENCY_MAX=6
# MACO_BASH_CONCURRENCY=1
# MACO_TOOL_BACKPRESSURE=queue   # or fail

# Telemetry: OTLP endpoint (optional); default uses ADK in-memory span exporter
# MACO_OTLP_ENDPOINT=http://localhost:4317

# ADK artifacts on Runner + load_artifacts tool; MACO_ADK_ARTIFACTS=0 disables
# MACO_ADK_ARTIFACTS=1

# LLM HTTP timeout in seconds (default 600; MiniMax / large tool JSON often exceed 60s)
# MACO_LLM_TIMEOUT_SECS=600